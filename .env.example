# PromptGuard AI Configuration
# Copy this file to .env and fill in your API keys

# =============================================================================
# LLM Provider API Keys (at least one required)
# =============================================================================

# Groq API Key (default provider)
# Get yours at: https://console.groq.com/keys
GROQ_API_KEY=your_groq_api_key_here

# OpenAI API Key (optional)
# OPENAI_API_KEY=your_openai_api_key_here

# Anthropic API Key (optional)
# ANTHROPIC_API_KEY=your_anthropic_api_key_here

# =============================================================================
# Application Settings
# =============================================================================

# Environment: development, staging, production
APP_ENV=development

# Enable debug mode (verbose logging)
DEBUG=false

# Log level: DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_LEVEL=INFO

# =============================================================================
# LLM Configuration
# =============================================================================

# LLM Provider: groq, openai, anthropic
LLM__PROVIDER=groq

# Model to use
LLM__MODEL=llama-3.1-8b-instant

# Generation temperature (0.0 - 2.0)
LLM__TEMPERATURE=0.7

# Maximum tokens in response
LLM__MAX_TOKENS=1024

# Request timeout in seconds
LLM__TIMEOUT=30.0

# Maximum retry attempts
LLM__MAX_RETRIES=3

# =============================================================================
# Evaluation Settings
# =============================================================================

# Minimum score to pass evaluation (0.0 - 1.0)
EVALUATION__PASS_THRESHOLD=0.7

# Score drop that indicates regression (0.0 - 1.0)
EVALUATION__REGRESSION_THRESHOLD=0.05

# Execute test cases in parallel
EVALUATION__PARALLEL_EXECUTION=false

# Maximum parallel workers
EVALUATION__MAX_WORKERS=4
